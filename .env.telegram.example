TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Route Bale account numbers to Telegram chat ids.
# Example: TELEGRAM_ACCOUNT_ROUTES=989121234567=123456789,989129876543=-1001234567890
# TELEGRAM_ACCOUNT_ROUTES=
# Legacy single-chat fallback. Used only when TELEGRAM_ACCOUNT_ROUTES is empty.
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
# Optional. Useful when TELEGRAM_CHAT_ID is a group chat.
# TELEGRAM_ALLOWED_USER_ID=your-telegram-user-id-here
# Shared secret must match the value in .env.bale.
RELAY_SHARED_SECRET=change-this-shared-secret
